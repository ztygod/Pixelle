{
  "name": "@pixelle/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pixelle-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "dev": "tsc -b tsconfig.json --watch --preserveWatchOutput",
    "dev:cli": "tsx src/cli.ts",
    "typecheck": "tsc -b tsconfig.json --pretty false"
  },
  "keywords": [],
  "author": "tianyi zhou",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "chalk": "^5.6.2",
    "diff": "^9.0.0",
    "ink": "^7.0.3",
    "openai": "^6.38.0",
    "react": "^19.2.6",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
